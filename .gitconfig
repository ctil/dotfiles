[alias]
	b = branch
	co = checkout
	st = status
	lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
	wt = worktree
	di = diff -- . ":(exclude,attr:linguist-generated=true)"

[push]
	default = current
	autoSetupRemote = true

[user]
	email = ctil@users.noreply.github.com
	name = ctil

[pull]
	ff = only

[core]
	editor = nvim
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true    # use n and N to move between diff sections
    side-by-side = true
    line-numbers = true
    true-color = always
    features = TokyoNight

[merge]
    conflictStyle = zdiff3

; Custom delta themes
[include]
    path = ~/.delta/themes.gitconfig

[delta "TokyoNight"]
    # Based on folke/tokyonight.nvim (night style)
    # bg=#1a1b26, bg_dark=#16161e, red=#f7768e, green=#9ece6a
    # magenta=#bb9af7, blue=#7aa2f7, cyan=#7dcfff, yellow=#e0af68
    dark = true
    syntax-theme = TwoDark

    # Diff backgrounds: darkened red/green tinted from the palette
    minus-style                   = syntax "#37222c"
    minus-emph-style              = syntax "#6b2737"
    plus-style                    = syntax "#20303b"
    plus-emph-style               = syntax "#2c5a3e"

    # Line numbers
    line-numbers                  = true
    line-numbers-zero-style       = "#3b4261"
    line-numbers-minus-style      = "#f7768e"
    line-numbers-plus-style       = "#9ece6a"
    line-numbers-left-style       = "#1f2335"
    line-numbers-right-style      = "#1f2335"

    # Hunk headers
    hunk-header-style             = file line-number syntax
    hunk-header-file-style        = "#7aa2f7"
    hunk-header-line-number-style = "#e0af68"
    hunk-header-decoration-style  = "#1f2335" box ul

    # File decoration
    file-style                    = "#7dcfff" bold
    file-decoration-style         = "#1f2335" ul

    # Commit decoration
    commit-decoration-style       = "#bb9af7" bold box
