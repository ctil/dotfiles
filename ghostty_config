# Map cmd+p to ctrl+p for use in Neovim
keybind = super+p=text:\x10

# Add clear screen binding that doesn't conflict with ctrl-l pane navigation
keybind = ctrl+enter=clear_screen

# Shift enter keybinding for claude code
keybind = shift+enter=text:\n

# No ligatures
font-feature = -calt, -liga, -dlig

# Misc features
font-size = 15
desktop-notifications = true
command = /opt/homebrew/bin/fish

# ------------------------------------------------------------------------------
# Themes
# ------------------------------------------------------------------------------

# Muted
# theme = Zenwritten Dark
# theme = Firewatch

# Dark
# theme = TokyoNight
# theme = Dark Modern

# Bold colors
# theme = Oxocarbon
theme = Carbonfox

